# tiger-eye configuration
# Copy to .env and fill in your values

# Database — points at tiger2go Postgres container
DATABASE_URL=postgresql+asyncpg://user:pass@tiger2go_postgres:5432/tiger2go

# For local dev (outside Docker), use:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/tiger2go

# OpenAI — required for LLM analysis and embeddings
OPENAI_API_KEY=sk-your-key-here

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Enrichment loop
ENRICH_INTERVAL=60
ENRICH_BATCH_SIZE=20

# Internal API
API_HOST=0.0.0.0
API_PORT=8080
